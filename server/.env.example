# Copy this file to server/.env and fill in the values.
# server/.env is gitignored and must never be committed.

# Port the backend listens on.
PORT=5001

# "sandbox" (default) or "production".
CLOVER_ENV=sandbox

# ── Test-token mode (fastest local path) ──────────────────────────────
# Get these from the Clover sandbox dashboard for a test merchant.
CLOVER_MERCHANT_ID=
CLOVER_TEST_ACCESS_TOKEN=

# Ecommerce API private key (DIFFERENT from the dashboard REST token above).
# Clover sandbox dashboard -> Ecommerce API tokens -> private key.
# Used as the Bearer token for the pay/charges endpoints (scl-sandbox.dev.clover.com).
CLOVER_ECOMMERCE_PRIVATE_KEY=
# Ecommerce API public key, from the same Ecommerce API token pair.
# Used as the `apikey` header to tokenize a card into a clv_ source token.
CLOVER_ECOMMERCE_PUBLIC_KEY=
# Optional: a static clv_ source token. Usually ephemeral; leave blank to mint
# a fresh token from a sandbox test card at pay-time.
CLOVER_TEST_SOURCE=

# ── OAuth mode (production-style) ─────────────────────────────────────
# Create a Clover WEB app (REST Clients = Web, not semi-integrated), set its
# Requested Permissions before installing, and use this redirect / launch path.
CLOVER_CLIENT_ID=
CLOVER_CLIENT_SECRET=
CLOVER_REDIRECT_URI=http://localhost:5001/api/clover/oauth/connect

# Where to send the browser after a successful OAuth connect.
# Optional; defaults to the Vite dev server.
# FRONTEND_URL=http://localhost:5173

# ── Base URL overrides (optional) ─────────────────────────────────────
# Defaults are derived from CLOVER_ENV; only set these to override.
# CLOVER_PLATFORM_BASE_URL=https://apisandbox.dev.clover.com
# CLOVER_ECOMMERCE_BASE_URL=https://scl-sandbox.dev.clover.com
# CLOVER_TOKENIZER_BASE_URL=https://token-sandbox.dev.clover.com
# CLOVER_OAUTH_BASE_URL=https://sandbox.dev.clover.com
# CLOVER_CHECKOUT_BASE_URL=https://checkout.sandbox.dev.clover.com
